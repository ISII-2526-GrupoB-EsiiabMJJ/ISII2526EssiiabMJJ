            "minLength": 1,
            "type": "string"
          },
          "reviewTitle": {
            "maxLength": 100,
            "minLength": 10,
            "type": "string",
            "nullable": true
          },
          "customerCountry": {
            "maxLength": 40,
            "minLength": 4,
            "type": "string",
            "nullable": true
          },
          "customerName": {
            "maxLength": 20,
            "minLength": 3,
            "type": "string",
            "nullable": true
          },
          "dateOfReview": {
            "type": "string",
            "format": "date-time"
          },
          "reviewItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReviewItemDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "DeviceDetailsDTO": {
        "type": "object",
