          "rentalDateTo": {
            "type": "string",
            "format": "date-time"
          },
          "deliveryAddress": {
            "maxLength": 50,
            "minLength": 10,
            "type": "string",
            "format": "multiline"
          },
          "customerUserName": {
            "minLength": 1,
            "type": "string"
          },
          "customerNameSurname": {
            "maxLength": 50,
            "minLength": 10,
            "type": "string"
          },
          "rentalItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RentalItemDTO"
