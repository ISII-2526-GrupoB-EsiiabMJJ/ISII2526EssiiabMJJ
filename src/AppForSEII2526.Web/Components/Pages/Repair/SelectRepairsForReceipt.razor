@page "/repair/selectrepairsforreceipt"
@attribute [Authorize]

@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization

@inject AppForSEII2526APIClient ApiClient
@inject ILogger<SelectRepairsForReceipt> Logger

<h3>Contratar reparación</h3>

<p>
    Selecciona las reparaciones disponibles para consultar su nombre, escala,
    descripción y coste. También puedes filtrar por nombre de reparación y escala.
</p>

<div class="card mb-4">
    <div class="card-header">
        <strong>Filtros de búsqueda</strong>
    </div>

    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-5">
                <label class="form-label" for="repairNameFilter">Nombre de la reparación</label>
                <InputText id="repairNameFilter"
                           class="form-control"
                           @bind-Value="RepairNameFilter"
                           placeholder="Ejemplo: pantalla, batería..." />
            </div>

            <div class="col-md-5">
                <label class="form-label" for="scaleFilter">Escala</label>
                <InputText id="scaleFilter"
                           class="form-control"
                           @bind-Value="ScaleFilter"
                           placeholder="Lujo, media o básica" />
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">
                <button class="btn btn-primary w-100"
                        type="button"
                        @onclick="SearchRepairs">
                    Buscar
                </button>
            </div>
        </div>

        <div class="mt-3">
            <button class="btn btn-outline-secondary"
                    type="button"
                    @onclick="ClearFilters">
                Limpiar filtros
            </button>
        </div>
    </div>
</div>

@if (IsLoading)
{
    <div class="alert alert-info">
        Cargando reparaciones...
    </div>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">
        @ErrorMessage
    </div>
}
else if (Repairs is null || !Repairs.Any())
{
    <div class="alert alert-warning">
        No hay reparaciones disponibles con los filtros seleccionados.
    </div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Escala</th>
                <th>Descripción</th>
                <th class="text-end">Coste</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var repair in Repairs)
            {
                <tr>
                    <td>@repair.Name</td>
                    <td>@repair.Scale</td>
                    <td>@repair.Description</td>
                    <td class="text-end">@repair.Cost.ToString("0.00") €</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private string? RepairNameFilter { get; set; }
    private string? ScaleFilter { get; set; }

    private ICollection<RepairForReceiptDTO> Repairs { get; set; } = new List<RepairForReceiptDTO>();

    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await SearchRepairs();
    }

    private async Task SearchRepairs()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var name = string.IsNullOrWhiteSpace(RepairNameFilter)
                ? null
                : RepairNameFilter.Trim();

            var scale = string.IsNullOrWhiteSpace(ScaleFilter)
                ? null
                : ScaleFilter.Trim();

            Repairs = await ApiClient.GetRepairsForReceiptAsync(name, scale);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading repairs for receipt");
            ErrorMessage = $"No se han podido cargar las reparaciones: {ex.Message}";
            Repairs = new List<RepairForReceiptDTO>();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task ClearFilters()
    {
        RepairNameFilter = null;
        ScaleFilter = null;

        await SearchRepairs();
    }
}