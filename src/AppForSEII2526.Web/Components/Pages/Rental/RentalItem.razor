@using AppForSEII2526.Web.API

<h3>RentalItem</h3>
<div class="card" style="width: 18rem;">
    <div class="card-body">
        <div class="d-flex justify-content-between">
            <div class="p-2">
                <p class="card-title" id="MovieSelected_@Item.Model">@Item.Model (@Item.PriceForRent €)</p>
            </div>
            <div class="p-2">
                <button class="btn-close" aria-label="Close" id="removeDevice_@Item.Model" @onclick="@(() => OnRemovedItem.InvokeAsync(Item))"></button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public RentalItemDTO Item { get; set; }

    [Parameter] public EventCallback<RentalItemDTO> OnRemovedItem { get; set; }


}